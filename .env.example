# ─────────────────────────────────────────────────────────────────────────────
# Community Tickets Bot — environment configuration
# Copy this file to `.env` and fill in your values. NEVER commit the real .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────────────────────
# Your bot token from https://discord.com/developers/applications
# (Bot → Reset Token). Keep it secret.
DISCORD_TOKEN=

# Your server (guild) ID — right-click your server icon → Copy Server ID.
# When set, slash commands register instantly to this server. Leave blank to
# register globally instead (can take up to an hour to appear).
GUILD_ID=

# ── Branding (optional) ──────────────────────────────────────────────────────
# Shown in the panel title and every embed footer.
COMMUNITY_NAME=Our Community
# Embed accent colour as a hex number, e.g. 0x1F6FEB (blue), 0xE67E22 (orange).
BRAND_COLOR=0x1F6FEB

# ── Transcripts (optional) ───────────────────────────────────────────────────
# Channel where closed-ticket transcripts + summaries are posted.
TICKETS_TRANSCRIPT_CHANNEL_ID=

# Persist ticket numbers across restarts by pointing this at a mounted volume,
# e.g. on Railway: /data/ticket-counter.json. If unset, numbers reset on redeploy.
TICKETS_COUNTER_PATH=

# ── Per-type categories (optional) ───────────────────────────────────────────
# Category each ticket type is created under. Leave blank to create tickets at
# the server root. Right-click a category → Copy ID.
TICKETS_MODERATION_CATEGORY_ID=
TICKETS_CUSTOMER_CATEGORY_ID=
TICKETS_ORDER_CATEGORY_ID=
TICKETS_HIGHRANK_CATEGORY_ID=
TICKETS_EXPO_CATEGORY_ID=

# ── Per-type staff roles (optional) ──────────────────────────────────────────
# Role granted access to (and able to claim) each ticket type. Without these,
# tickets still open but no team is auto-added. Right-click a role → Copy ID.
TICKETS_MODERATION_ROLE_ID=
TICKETS_CUSTOMER_ROLE_ID=
TICKETS_ORDER_ROLE_ID=
TICKETS_HIGHRANK_ROLE_ID=
TICKETS_EXPO_ROLE_ID=
